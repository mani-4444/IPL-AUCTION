# ── Supabase ─────────────────────────────────────────────────────────────────
# Get these from: Supabase → Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ── Server ────────────────────────────────────────────────────────────────────
# Local dev: 4000
# Render:    10000 (set automatically by Render — render.yaml sets it to 10000)
PORT=4000

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
# Local:
CLIENT_URL=http://localhost:3000
# Production (set this to your Vercel URL in Render dashboard):
# CLIENT_URL=https://ipl-auction.vercel.app
# Multiple origins: CLIENT_URL=https://ipl-auction.vercel.app,https://ipl-auction-git-main.vercel.app
